{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "masar-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true,
      "env": { "NEXT_DIST_DIR": ".next-preview" }
    },
    {
      "name": "masar-dev-alt",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "autoPort": true,
      "env": { "NEXT_DIST_DIR": ".next-preview-alt" }
    },
    {
      "name": "masar-prod",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "start", "-p", "3200"],
      "port": 3200,
      "env": { "NEXT_DIST_DIR": ".next-agent" }
    }
  ]
}
